# Supabase for the second isolated site
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server aliases used by some helpers
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Web Push for the second isolated site
WEB_PUSH_SUBJECT=mailto:admin@example.com
WEB_PUSH_PRIVATE_KEY=
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=

# Dedicated WhatsApp worker session for the second isolated site
WHATSAPP_CLIENT_ID=habib-isolated-instance
WHATSAPP_AUTH_DIR=./whatsapp-worker/.wwebjs_auth_isolated
WHATSAPP_QR_IMAGE_PATH=./whatsapp-worker/current-qr-isolated.png
WHATSAPP_STATUS_FILE_PATH=./whatsapp-worker/status-isolated.json
WHATSAPP_COMMAND_FILE_PATH=./whatsapp-worker/command-isolated.json
WHATSAPP_LOCK_FILE_PATH=./whatsapp-worker/worker-isolated.lock

# Optional runtime tuning
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
# WHATSAPP_MIN_DELAY_MS=20000
# WHATSAPP_MAX_DELAY_MS=45000
