NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_without_prefix

WEB_PUSH_SUBJECT=mailto:admin@example.com
WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your_web_push_public_key

WHATSAPP_CLIENT_ID=habib-isolated-instance
WHATSAPP_AUTH_DIR=/var/www/habib-isolated-instance/whatsapp-worker/.wwebjs_auth_isolated
WHATSAPP_QR_IMAGE_PATH=/var/www/habib-isolated-instance/whatsapp-worker/current-qr-isolated.png
WHATSAPP_STATUS_FILE_PATH=/var/www/habib-isolated-instance/whatsapp-worker/status-isolated.json
WHATSAPP_COMMAND_FILE_PATH=/var/www/habib-isolated-instance/whatsapp-worker/command-isolated.json
WHATSAPP_LOCK_FILE_PATH=/var/www/habib-isolated-instance/whatsapp-worker/worker-isolated.lock
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

WHATSAPP_MIN_DELAY_MS=20000
WHATSAPP_MAX_DELAY_MS=45000
WHATSAPP_BURST_SIZE=10
WHATSAPP_BURST_PAUSE_MIN_MS=30000
WHATSAPP_BURST_PAUSE_MAX_MS=60000
WHATSAPP_INCOMING_SYNC_INTERVAL_MS=30000
WHATSAPP_INCOMING_SYNC_CHAT_LIMIT=30
WHATSAPP_INCOMING_SYNC_MESSAGE_LIMIT=8
WHATSAPP_HEARTBEAT_INTERVAL_MS=15000