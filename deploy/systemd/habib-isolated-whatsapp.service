[Unit]
Description=Habib Isolated WhatsApp Worker
After=network.target habib-isolated-app.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/habib-isolated-instance
EnvironmentFile=/var/www/habib-isolated-instance/.env.local
Environment=NODE_ENV=production
ExecStart=/usr/bin/pnpm worker:whatsapp
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=habib-isolated-whatsapp

[Install]
WantedBy=multi-user.target